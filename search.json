---
layout: null
permalink: /search.json
sitemap: false
---
[
  {%- assign all_posts = "" | split: "" -%}
  {%- assign all_posts = all_posts | concat: site.writing -%}
  {%- assign all_posts = all_posts | concat: site.talks -%}
  {%- for post in all_posts -%}
    {
      "id": {{ forloop.index | jsonify }},
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | relative_url | jsonify }},
      "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
      "tags": {{ post.tags | default: empty | jsonify }},
      "content": {{ post.content | strip_html | normalize_whitespace | jsonify }}
    }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]
