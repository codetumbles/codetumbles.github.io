#!/usr/bin/env bash
# Usage: bin/new-post "My Post Title"
# Creates _writing/YYYY-MM-DD-slug.md with the standard front matter.

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 \"Post title\"" >&2
  exit 1
fi

title="$1"
slug=$(echo "$title" \
  | tr '[:upper:]' '[:lower:]' \
  | sed 's/[^a-z0-9]/-/g' \
  | sed 's/--*/-/g' \
  | sed 's/^-//; s/-$//')
date=$(date +%Y-%m-%d)
file="_writing/${date}-${slug}.md"

if [[ -e "$file" ]]; then
  echo "$file already exists." >&2
  exit 1
fi

cat > "$file" <<EOF
---
title: "$title"
date: $date
last_updated: $date
tags: []
toc: false
---

EOF

echo "Created $file"
