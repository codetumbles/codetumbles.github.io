#!/usr/bin/env python3
"""
Generate the site-wide default Open Graph image at assets/og/default.png.

Per-post OG images can either be hand-authored (drop a 1200x630 PNG into
`assets/og/<slug>.png` and add `image: /assets/og/<slug>.png` to the post's
front matter) or generated by extending this script.

Run:  bin/make-og-image
Requires: Pillow (`pip install Pillow`)
"""
from pathlib import Path
from PIL import Image, ImageDraw, ImageFont
import sys

WIDTH, HEIGHT = 1200, 630
BG_DARK = (15, 17, 21)
BG_ACCENT = (211, 54, 130)
FG = (240, 240, 240)
FG_MUTED = (180, 180, 180)

TITLE = "Code Tumbles"
SUBTITLE = "Notes on machine learning, software, and engineering"
URL = "codingtumbleweed.github.io/blog"


def find_font(size, bold=False):
    candidates = [
        "/System/Library/Fonts/Supplemental/Arial Bold.ttf" if bold else "/System/Library/Fonts/Helvetica.ttc",
        "/System/Library/Fonts/Helvetica.ttc",
        "/Library/Fonts/Arial.ttf",
        "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf" if bold else "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
    ]
    for p in candidates:
        if Path(p).exists():
            try:
                return ImageFont.truetype(p, size)
            except (OSError, IOError):
                continue
    return ImageFont.load_default()


def main():
    out = Path(__file__).resolve().parent.parent / "assets" / "og" / "default.png"
    out.parent.mkdir(parents=True, exist_ok=True)

    img = Image.new("RGB", (WIDTH, HEIGHT), BG_DARK)
    draw = ImageDraw.Draw(img)

    draw.rectangle([(0, HEIGHT - 12), (WIDTH, HEIGHT)], fill=BG_ACCENT)

    title_font = find_font(96, bold=True)
    sub_font = find_font(36)
    url_font = find_font(28)

    pad_x = 80
    draw.text((pad_x, 200), TITLE, fill=FG, font=title_font)
    draw.text((pad_x, 330), SUBTITLE, fill=FG_MUTED, font=sub_font)
    draw.text((pad_x, HEIGHT - 90), URL, fill=FG_MUTED, font=url_font)

    img.save(out, "PNG", optimize=True)
    print(f"Wrote {out} ({out.stat().st_size:,} bytes)")


if __name__ == "__main__":
    sys.exit(main())
